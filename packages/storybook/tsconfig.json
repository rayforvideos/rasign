{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@rasign/react": ["../react/src/index.ts"]
    }
  },
  "include": [".storybook/**/*.ts", "stories/**/*.tsx", "stories/**/*.ts"],
  "exclude": ["node_modules"]
}
